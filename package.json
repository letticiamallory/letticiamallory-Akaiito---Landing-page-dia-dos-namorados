{
  "name": "valentinesday",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "drizzle-kit push",
    "record-demo": "tsx scripts/record-demo.ts",
    "capture-hero-shots": "tsx scripts/capture-hero-screenshots.ts",
    "optimize-svgs": "tsx scripts/optimize-svgs.ts",
    "verify-deploy": "tsx scripts/verify-deploy.ts",
    "test": "npm run verify-deploy",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run verify-deploy -- --skip-build && npm run test:e2e"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "html2canvas": "^1.4.1",
    "mercadopago": "^3.1.0",
    "nanoid": "^5.1.11",
    "next": "16.2.7",
    "postgres": "^3.4.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "glob": "^13.0.6",
    "playwright": "^1.52.0",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
